# Base URL used by the Axios client. In dev/prod the SPA calls same-origin
# "/api" (Vite proxy in dev, Nginx reverse proxy in prod), so the default
# below normally doesn't need to change.
VITE_API_BASE_URL=/api

# Target used ONLY by the Vite dev server to proxy "/api" requests to the
# backend while developing. Assumes the ASP.NET Core API's default HTTP dev
# port (5080); adjust if your local backend launch profile uses another port.
VITE_API_PROXY_TARGET=http://localhost:5080
