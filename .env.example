# Copia este archivo a `.env` y ajusta los valores antes de `docker compose up`.

# --- PostgreSQL ---
POSTGRES_USER=gestor
POSTGRES_PASSWORD=gestor
POSTGRES_DB=gestor_gastos

# --- JWT ---
# Obligatorio. Usa una cadena larga y aleatoria (mínimo 32 caracteres).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-chars
JWT_ISSUER=GestorGastos
JWT_AUDIENCE=GestorGastos
JWT_EXPIRY_MINUTES=60

# --- Puertos publicados en el host ---
WEB_PORT=5173
API_PORT=5080
DB_PORT=5432
