# Copia este archivo a `.env` y ajusta los valores antes de `docker compose up`.

# --- PostgreSQL ---
POSTGRES_USER=gestor
POSTGRES_PASSWORD=gestor
POSTGRES_DB=gestor_gastos

# --- JWT ---
# Obligatorio. Usa una cadena larga y aleatoria (mínimo 32 caracteres).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-chars
JWT_ISSUER=GestorGastos
JWT_AUDIENCE=GestorGastos
# Duración del token de acceso (minutos). La sesión se renueva con refresh tokens.
JWT_EXPIRY_MINUTES=15

# --- 2FA (TOTP) ---
# Obligatorio. Clave de 32 bytes en base64 para cifrar los secretos TOTP en reposo.
# Genera una propia con: openssl rand -base64 32
# El valor de abajo es solo para desarrollo local; en producción usa uno distinto.
TOTP_ENCRYPTION_KEY=fvGeEHhbmbngW9dUujC3EmwJnhwT2wxSuQc1hbafHIg=

# --- Puertos publicados en el host ---
WEB_PORT=5173
API_PORT=5080
DB_PORT=5432
